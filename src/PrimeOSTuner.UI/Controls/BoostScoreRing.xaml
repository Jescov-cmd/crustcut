<UserControl x:Class="PrimeOSTuner.UI.Controls.BoostScoreRing"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="100" Height="100">
    <Grid>
        <Ellipse Width="100" Height="100"
                 Stroke="{StaticResource StrokeBrush}"
                 StrokeThickness="8"/>
        <Path x:Name="Arc" StrokeThickness="8" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
            <Path.Effect>
                <DropShadowEffect Color="#C8995F" BlurRadius="22" ShadowDepth="0" Opacity="0.85"/>
            </Path.Effect>
        </Path>
        <TextBlock x:Name="ScoreText" Text="0" FontSize="28" FontWeight="Bold"
                   HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock.Effect>
                <DropShadowEffect Color="#F0D6A4" BlurRadius="14" ShadowDepth="0" Opacity="0.6"/>
            </TextBlock.Effect>
        </TextBlock>
    </Grid>
</UserControl>
