<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Icon set — Fluent / Windows 11 style.
        24×24 viewport, ~1.75 stroke, rounded caps and joins, single neutral color.
        DrawingImage scales to whatever Image.Width/Height the consumer sets.
    -->

    <SolidColorBrush x:Key="IconBrush" Color="#E6FFFFFF"/>
    <SolidColorBrush x:Key="IconAccentBrush" Color="#F77254"/>

    <!-- ============================================================
         DASHBOARD (gauge / speedometer)
         ============================================================ -->
    <DrawingImage x:Key="IconDashboard">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconBrush}" Thickness="1.75" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 4,17 A 8,8 0 0 1 20,17 M 12,17 L 16,9"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="{StaticResource IconBrush}">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="12,17" RadiusX="1.5" RadiusY="1.5"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         OPTIMIZE (sliders)
         ============================================================ -->
    <DrawingImage x:Key="IconOptimize">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconBrush}" Thickness="1.75" StartLineCap="Round" EndLineCap="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 4,7 H 20 M 4,12 H 20 M 4,17 H 20"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="{StaticResource IconBrush}">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <EllipseGeometry Center="15,7" RadiusX="2" RadiusY="2"/>
                            <EllipseGeometry Center="9,12" RadiusX="2" RadiusY="2"/>
                            <EllipseGeometry Center="17,17" RadiusX="2" RadiusY="2"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         GAME BOOST (rocket)
         ============================================================ -->
    <DrawingImage x:Key="IconGameBoost">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconBrush}" Thickness="1.75" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 12,3 C 9.5,6 8,10 8,14 V 18 H 16 V 14 C 16,10 14.5,6 12,3 Z M 8,18 L 6,21 M 16,18 L 18,21"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconBrush}" Thickness="1.5"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="12,11" RadiusX="1.8" RadiusY="1.8"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         GAME LIBRARY (controller)
         ============================================================ -->
    <DrawingImage x:Key="IconGameLibrary">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconBrush}" Thickness="1.75" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 5,9 H 19 A 3,3 0 0 1 22,12 V 14 A 3,3 0 0 1 17,16 L 15,14 H 9 L 7,16 A 3,3 0 0 1 2,14 V 12 A 3,3 0 0 1 5,9 Z M 7,11 V 14 M 5.5,12.5 H 8.5"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="{StaticResource IconBrush}">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <EllipseGeometry Center="16,12" RadiusX="0.9" RadiusY="0.9"/>
                            <EllipseGeometry Center="17.5,13.5" RadiusX="0.9" RadiusY="0.9"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         BLOATWARE (broom)
         ============================================================ -->
    <DrawingImage x:Key="IconBloatware">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconBrush}" Thickness="1.75" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 19,4 L 11,12 M 14,9 L 18,5 M 5,21 L 10,16 H 16 L 13,21 Z M 7.5,17 V 21 M 10,17 V 21 M 12.5,17 V 21"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         MEMORY PRIORITY (RAM stick)
         ============================================================ -->
    <DrawingImage x:Key="IconMemoryPriority">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconBrush}" Thickness="1.75" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 3,7 H 21 V 17 H 3 Z M 7,7 V 17 M 11,7 V 17 M 15,7 V 17 M 3,12 H 21 M 9,19 V 21 M 15,19 V 21"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         HISTORY (clock with rewind arrow)
         ============================================================ -->
    <DrawingImage x:Key="IconHistory">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconBrush}" Thickness="1.75" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 3,12 A 9,9 0 1 0 6,5.3 L 3,8 M 3,4 V 8 H 7 M 12,8 V 12 L 15,14"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         SETTINGS (gear)
         ============================================================ -->
    <DrawingImage x:Key="IconSettings">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconBrush}" Thickness="1.75" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 12,2 V 5 M 12,19 V 22 M 2,12 H 5 M 19,12 H 22 M 4.93,4.93 L 7.05,7.05 M 16.95,16.95 L 19.07,19.07 M 4.93,19.07 L 7.05,16.95 M 16.95,7.05 L 19.07,4.93"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconBrush}" Thickness="1.75"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="12,12" RadiusX="3" RadiusY="3"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         WARNING (caution triangle) — uses accent color
         ============================================================ -->
    <DrawingImage x:Key="IconWarning">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#FFA01F" Thickness="1.75" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 12,3 L 22,20 H 2 Z M 12,10 V 14"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#FFA01F">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="12,17.5" RadiusX="1" RadiusY="1"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         LOCK (padlock)
         ============================================================ -->
    <DrawingImage x:Key="IconLock">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconBrush}" Thickness="1.75" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 5,11 H 19 V 20 H 5 Z M 8,11 V 8 A 4,4 0 0 1 16,8 V 11 M 12,15 V 17"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="{StaticResource IconBrush}">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="12,15" RadiusX="0.9" RadiusY="0.9"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         CHECK (success / safe) — green
         ============================================================ -->
    <DrawingImage x:Key="IconCheck">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#2ECC71" Thickness="1.75" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 12,3 A 9,9 0 1 1 12,21 A 9,9 0 1 1 12,3 Z M 8,12.5 L 11,15.5 L 16,9.5"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         LIGHTNING (boost / quick action) — accent
         ============================================================ -->
    <DrawingImage x:Key="IconLightning">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="{StaticResource IconAccentBrush}">
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconAccentBrush}" Thickness="1.5" LineJoin="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 13,3 L 4,14 H 10 L 9,21 L 18,10 H 12 L 13,3 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         RESTART (reboot circular arrow)
         ============================================================ -->
    <DrawingImage x:Key="IconRestart">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconBrush}" Thickness="1.75" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 21,12 A 9,9 0 1 1 18.4,5.6 M 21,4 V 9 H 16"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         MODE 1 / BASIC — single rocket
         ============================================================ -->
    <DrawingImage x:Key="IconModeBasic">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconAccentBrush}" Thickness="1.75" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 12,2 C 9.5,5 8,9 8,14 V 18 H 16 V 14 C 16,9 14.5,5 12,2 Z M 8,18 L 6,21 M 16,18 L 18,21"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconAccentBrush}" Thickness="1.5"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="12,10" RadiusX="1.8" RadiusY="1.8"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         MODE 2 / PERFORMANCE — two rockets
         ============================================================ -->
    <DrawingImage x:Key="IconModePerformance">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconAccentBrush}" Thickness="1.5" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 7,4 C 5.4,6 4.5,9 4.5,12.5 V 15.5 H 9.5 V 12.5 C 9.5,9 8.6,6 7,4 Z M 4.5,15.5 L 3.4,17.5 M 9.5,15.5 L 10.6,17.5 M 17,4 C 15.4,6 14.5,9 14.5,12.5 V 15.5 H 19.5 V 12.5 C 19.5,9 18.6,6 17,4 Z M 14.5,15.5 L 13.4,17.5 M 19.5,15.5 L 20.6,17.5"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconAccentBrush}" Thickness="1.25"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <EllipseGeometry Center="7,10" RadiusX="1.2" RadiusY="1.2"/>
                            <EllipseGeometry Center="17,10" RadiusX="1.2" RadiusY="1.2"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         MODE 3 / AGGRESSIVE — three rockets
         ============================================================ -->
    <DrawingImage x:Key="IconModeAggressive">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconAccentBrush}" Thickness="1.4" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 4.5,5 C 3.2,6.6 2.5,9 2.5,12 V 14.5 H 6.5 V 12 C 6.5,9 5.8,6.6 4.5,5 Z M 12,3 C 10.4,5 9.5,8 9.5,11.5 V 14.5 H 14.5 V 11.5 C 14.5,8 13.6,5 12,3 Z M 19.5,5 C 18.2,6.6 17.5,9 17.5,12 V 14.5 H 21.5 V 12 C 21.5,9 20.8,6.6 19.5,5 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

</ResourceDictionary>
