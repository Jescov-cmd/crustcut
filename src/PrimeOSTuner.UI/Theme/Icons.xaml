<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Icon set — Lucide icons (https://lucide.dev), MIT licensed.
        24×24 viewport, 2px stroke, rounded caps & joins.
        Path data taken verbatim from Lucide v1.14 SVGs.
    -->

    <SolidColorBrush x:Key="IconBrush" Color="#E6FFFFFF"/>
    <SolidColorBrush x:Key="IconAccentBrush" Color="#F77254"/>

