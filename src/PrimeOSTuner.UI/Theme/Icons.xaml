<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Icon set — Lucide icons (https://lucide.dev), MIT licensed.
        24×24 viewport, 2px stroke, rounded caps & joins.
        Path data taken verbatim from Lucide v1.14 SVGs.
    -->

    <SolidColorBrush x:Key="IconBrush" Color="#E6FFFFFF"/>
    <SolidColorBrush x:Key="IconAccentBrush" Color="#C8995F"/>

    <!-- DASHBOARD — gauge -->
    <DrawingImage x:Key="IconDashboard">
        <DrawingImage.Drawing>
            <GeometryDrawing>
                <GeometryDrawing.Pen>
                    <Pen Brush="{StaticResource IconBrush}" Thickness="2" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/>
                </GeometryDrawing.Pen>
                <GeometryDrawing.Geometry>
                    <PathGeometry Figures="M 12,14 L 16,10 M 3.34,19 a 10,10 0 1 1 17.32,0"/>
                </GeometryDrawing.Geometry>
            </GeometryDrawing>
        </DrawingImage.Drawing>
    </DrawingImage>

