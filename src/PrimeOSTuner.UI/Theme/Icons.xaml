    <!-- ============================================================
         MODE icons — speedometer gauge with the needle at low / mid /
         full tilt for Basic / Performance / Aggressive. 24x24 viewBox,
         half-arc above a pivot at (12,15).
         ============================================================ -->

    <!-- MODE 1 / BASIC — needle low-left -->
    <DrawingImage x:Key="IconModeBasic">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconAccentBrush}" Thickness="1.8"
