<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        3D-style app icons.
        Each is a DrawingImage at 64×64 logical units. Built from layers:
            1. Rounded-square base filled with the brand pink→orange gradient
            2. Inner highlight (white-ish gradient on the top half)
            3. Outer glow / drop shadow simulated with a soft outline
            4. The glyph itself in white on top
        Colors come from the brand palette (#F77254 → #FFA01F) so they sit
        with the rest of the app's accents.
    -->

    <!-- Shared brushes used by every icon -->
    <LinearGradientBrush x:Key="IconBaseBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F77254" Offset="0"/>
        <GradientStop Color="#FFA01F" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="IconHighlightBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#55FFFFFF" Offset="0"/>
        <GradientStop Color="#11FFFFFF" Offset="0.45"/>
        <GradientStop Color="#00FFFFFF" Offset="0.6"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="IconShadowBrush" Color="#33000000"/>
    <SolidColorBrush x:Key="IconGlyphBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="IconGlyphSoftBrush" Color="#E6FFFFFF"/>

    <!-- ============================================================
         Helper: every icon is a DrawingImage built like this.
         The "tile" layers (rounded base + shadow + highlight) are the
         same for every icon; only the glyph Geometry changes.
         ============================================================ -->

    <!-- Base tile (rounded gradient square) — re-used by all icons -->
    <RectangleGeometry x:Key="IconTileGeometry" Rect="6,6,52,52" RadiusX="14" RadiusY="14"/>
    <RectangleGeometry x:Key="IconShadowGeometry" Rect="8,10,52,52" RadiusX="14" RadiusY="14"/>
    <RectangleGeometry x:Key="IconHighlightGeometry" Rect="6,6,52,28" RadiusX="14" RadiusY="14"/>

    <!-- ============================================================
         DASHBOARD (gauge / speedometer)
         ============================================================ -->
    <DrawingImage x:Key="IconDashboard">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="{StaticResource IconShadowBrush}" Geometry="{StaticResource IconShadowGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}" Geometry="{StaticResource IconTileGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconHighlightBrush}" Geometry="{StaticResource IconHighlightGeometry}"/>
                <!-- Gauge arc -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconGlyphBrush}" Thickness="3.5" StartLineCap="Round" EndLineCap="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 20,42 A 12,12 0 0 1 44,42"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Needle -->
                <GeometryDrawing Brush="{StaticResource IconGlyphBrush}">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 32,42 L 41,26 L 38,42 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Center hub -->
                <GeometryDrawing Brush="{StaticResource IconGlyphBrush}">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="32,42" RadiusX="2.5" RadiusY="2.5"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         OPTIMIZE (sliders)
         ============================================================ -->
    <DrawingImage x:Key="IconOptimize">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="{StaticResource IconShadowBrush}" Geometry="{StaticResource IconShadowGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}" Geometry="{StaticResource IconTileGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconHighlightBrush}" Geometry="{StaticResource IconHighlightGeometry}"/>
                <!-- Three slider tracks -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconGlyphSoftBrush}" Thickness="2" StartLineCap="Round" EndLineCap="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 16,22 L 48,22 M 16,32 L 48,32 M 16,42 L 48,42"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Slider knobs -->
                <GeometryDrawing Brush="{StaticResource IconGlyphBrush}">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <EllipseGeometry Center="38,22" RadiusX="4" RadiusY="4"/>
                            <EllipseGeometry Center="22,32" RadiusX="4" RadiusY="4"/>
                            <EllipseGeometry Center="42,42" RadiusX="4" RadiusY="4"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         GAME BOOST (rocket)
         ============================================================ -->
    <DrawingImage x:Key="IconGameBoost">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="{StaticResource IconShadowBrush}" Geometry="{StaticResource IconShadowGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}" Geometry="{StaticResource IconTileGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconHighlightBrush}" Geometry="{StaticResource IconHighlightGeometry}"/>
                <!-- Rocket body -->
                <GeometryDrawing Brush="{StaticResource IconGlyphBrush}">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 32,16 C 26,22 24,30 24,38 L 24,44 L 40,44 L 40,38 C 40,30 38,22 32,16 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Window -->
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="32,30" RadiusX="3" RadiusY="3"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Side fins -->
                <GeometryDrawing Brush="{StaticResource IconGlyphBrush}">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <PathGeometry Figures="M 24,38 L 18,46 L 24,44 Z"/>
                            <PathGeometry Figures="M 40,38 L 46,46 L 40,44 Z"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Flame -->
                <GeometryDrawing Brush="#FFFFE066">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 28,44 L 32,52 L 36,44 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         GAME LIBRARY (controller)
         ============================================================ -->
    <DrawingImage x:Key="IconGameLibrary">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="{StaticResource IconShadowBrush}" Geometry="{StaticResource IconShadowGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}" Geometry="{StaticResource IconTileGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconHighlightBrush}" Geometry="{StaticResource IconHighlightGeometry}"/>
                <!-- Controller body -->
                <GeometryDrawing Brush="{StaticResource IconGlyphBrush}">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 18,26 C 16,26 14,28 14,32 L 14,38 C 14,42 16,44 19,44 C 22,44 23,40 25,40 L 39,40 C 41,40 42,44 45,44 C 48,44 50,42 50,38 L 50,32 C 50,28 48,26 46,26 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- D-pad cross -->
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 22,32 L 22,36 L 18,34 L 22,32 Z M 22,32 L 26,34 L 22,36 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- D-pad horizontal -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconBaseBrush}" Thickness="2" StartLineCap="Round" EndLineCap="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 18,34 L 26,34 M 22,30 L 22,38"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- A and B buttons -->
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <EllipseGeometry Center="42,32" RadiusX="2" RadiusY="2"/>
                            <EllipseGeometry Center="46,36" RadiusX="2" RadiusY="2"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         BLOATWARE (broom)
         ============================================================ -->
    <DrawingImage x:Key="IconBloatware">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="{StaticResource IconShadowBrush}" Geometry="{StaticResource IconShadowGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}" Geometry="{StaticResource IconTileGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconHighlightBrush}" Geometry="{StaticResource IconHighlightGeometry}"/>
                <!-- Broom handle -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconGlyphBrush}" Thickness="3" StartLineCap="Round" EndLineCap="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 44,18 L 30,32"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Broom head body -->
                <GeometryDrawing Brush="{StaticResource IconGlyphBrush}">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 22,38 L 38,38 L 42,46 L 18,46 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Broom bristles -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconBaseBrush}" Thickness="1.5" StartLineCap="Round" EndLineCap="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 24,40 L 22,46 M 28,40 L 28,46 M 32,40 L 33,46 M 36,40 L 38,46"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         MEMORY PRIORITY (RAM stick)
         ============================================================ -->
    <DrawingImage x:Key="IconMemoryPriority">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="{StaticResource IconShadowBrush}" Geometry="{StaticResource IconShadowGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}" Geometry="{StaticResource IconTileGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconHighlightBrush}" Geometry="{StaticResource IconHighlightGeometry}"/>
                <!-- RAM body -->
                <GeometryDrawing Brush="{StaticResource IconGlyphBrush}">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="14,22 36,20" RadiusX="2" RadiusY="2"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Chip dividers -->
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <RectangleGeometry Rect="22,26 1.5,12"/>
                            <RectangleGeometry Rect="32,26 1.5,12"/>
                            <RectangleGeometry Rect="42,26 1.5,12"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Pins on bottom -->
                <GeometryDrawing Brush="{StaticResource IconGlyphBrush}">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <RectangleGeometry Rect="20,42 4,2.5"/>
                            <RectangleGeometry Rect="30,42 4,2.5"/>
                            <RectangleGeometry Rect="40,42 4,2.5"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         HISTORY (clock with rewind arrow)
         ============================================================ -->
    <DrawingImage x:Key="IconHistory">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="{StaticResource IconShadowBrush}" Geometry="{StaticResource IconShadowGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}" Geometry="{StaticResource IconTileGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconHighlightBrush}" Geometry="{StaticResource IconHighlightGeometry}"/>
                <!-- Clock body -->
                <GeometryDrawing Brush="{StaticResource IconGlyphBrush}">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="34,32" RadiusX="11" RadiusY="11"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Clock face inner -->
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="34,32" RadiusX="8.5" RadiusY="8.5"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Clock hands -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconGlyphBrush}" Thickness="2" StartLineCap="Round" EndLineCap="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 34,32 L 34,26 M 34,32 L 39,34"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Rewind arrow loop -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconGlyphBrush}" Thickness="2.5" StartLineCap="Round" EndLineCap="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 22,22 L 17,22 L 17,17"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         SETTINGS (gear)
         ============================================================ -->
    <DrawingImage x:Key="IconSettings">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="{StaticResource IconShadowBrush}" Geometry="{StaticResource IconShadowGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}" Geometry="{StaticResource IconTileGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconHighlightBrush}" Geometry="{StaticResource IconHighlightGeometry}"/>
                <!-- Gear teeth (8-tooth gear) -->
                <GeometryDrawing Brush="{StaticResource IconGlyphBrush}">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 30,16 L 34,16 L 35,20 L 39,21 L 42,18 L 45,21 L 42,24 L 43,28 L 47,29 L 47,33 L 43,34 L 42,38 L 45,41 L 42,44 L 39,41 L 35,42 L 34,46 L 30,46 L 29,42 L 25,41 L 22,44 L 19,41 L 22,38 L 21,34 L 17,33 L 17,29 L 21,28 L 22,24 L 19,21 L 22,18 L 25,21 L 29,20 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Inner ring -->
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="32,31" RadiusX="5.5" RadiusY="5.5"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         WARNING (caution triangle)
         ============================================================ -->
    <DrawingImage x:Key="IconWarning">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="{StaticResource IconShadowBrush}" Geometry="{StaticResource IconShadowGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}" Geometry="{StaticResource IconTileGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconHighlightBrush}" Geometry="{StaticResource IconHighlightGeometry}"/>
                <!-- Triangle -->
                <GeometryDrawing Brush="{StaticResource IconGlyphBrush}">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 32,16 L 48,44 L 16,44 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Exclamation -->
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <RectangleGeometry Rect="30.5,24 3,12" RadiusX="1.5" RadiusY="1.5"/>
                            <EllipseGeometry Center="32,40" RadiusX="2" RadiusY="2"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         LOCK (padlock)
         ============================================================ -->
    <DrawingImage x:Key="IconLock">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="{StaticResource IconShadowBrush}" Geometry="{StaticResource IconShadowGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}" Geometry="{StaticResource IconTileGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconHighlightBrush}" Geometry="{StaticResource IconHighlightGeometry}"/>
                <!-- Shackle -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconGlyphBrush}" Thickness="3" StartLineCap="Round" EndLineCap="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 24,30 L 24,24 A 8,8 0 0 1 40,24 L 40,30"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Body -->
                <GeometryDrawing Brush="{StaticResource IconGlyphBrush}">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="18,30 28,18" RadiusX="3" RadiusY="3"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Keyhole -->
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <EllipseGeometry Center="32,38" RadiusX="2.5" RadiusY="2.5"/>
                            <RectangleGeometry Rect="31,38 2,5"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         CHECK (success checkmark in circle)
         ============================================================ -->
    <DrawingImage x:Key="IconCheck">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="{StaticResource IconShadowBrush}" Geometry="{StaticResource IconShadowGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}" Geometry="{StaticResource IconTileGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconHighlightBrush}" Geometry="{StaticResource IconHighlightGeometry}"/>
                <!-- Checkmark -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconGlyphBrush}" Thickness="5" StartLineCap="Round" EndLineCap="Round" LineJoin="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 20,32 L 29,40 L 44,24"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         LIGHTNING (boost / quick action)
         ============================================================ -->
    <DrawingImage x:Key="IconLightning">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="{StaticResource IconShadowBrush}" Geometry="{StaticResource IconShadowGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}" Geometry="{StaticResource IconTileGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconHighlightBrush}" Geometry="{StaticResource IconHighlightGeometry}"/>
                <!-- Bolt -->
                <GeometryDrawing Brush="{StaticResource IconGlyphBrush}">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 36,14 L 22,34 L 30,34 L 28,50 L 42,30 L 34,30 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         MODE 1 / BASIC — single rocket
         ============================================================ -->
    <DrawingImage x:Key="IconModeBasic">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="{StaticResource IconShadowBrush}" Geometry="{StaticResource IconShadowGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}" Geometry="{StaticResource IconTileGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconHighlightBrush}" Geometry="{StaticResource IconHighlightGeometry}"/>
                <!-- Flame -->
                <GeometryDrawing Brush="#FFFFE066">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 28,46 L 32,52 L 36,46 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Rocket body + fins -->
                <GeometryDrawing Brush="{StaticResource IconGlyphBrush}">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 32,14 L 39,28 L 39,40 L 43,44 L 39,44 L 39,46 L 25,46 L 25,44 L 21,44 L 25,40 L 25,28 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Window -->
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="32,30" RadiusX="2.5" RadiusY="2.5"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         MODE 2 / PERFORMANCE — two rockets
         ============================================================ -->
    <DrawingImage x:Key="IconModePerformance">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="{StaticResource IconShadowBrush}" Geometry="{StaticResource IconShadowGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}" Geometry="{StaticResource IconTileGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconHighlightBrush}" Geometry="{StaticResource IconHighlightGeometry}"/>
                <!-- Flames (left + right) -->
                <GeometryDrawing Brush="#FFFFE066">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <PathGeometry Figures="M 21,46 L 24,50 L 27,46 Z"/>
                            <PathGeometry Figures="M 37,46 L 40,50 L 43,46 Z"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Rocket bodies (left + right) -->
                <GeometryDrawing Brush="{StaticResource IconGlyphBrush}">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <!-- Left rocket centered at (24, 32) -->
                            <PathGeometry Figures="M 24,18 L 29,28 L 29,38 L 32,42 L 29,42 L 29,44 L 19,44 L 19,42 L 16,42 L 19,38 L 19,28 Z"/>
                            <!-- Right rocket centered at (40, 32) -->
                            <PathGeometry Figures="M 40,18 L 45,28 L 45,38 L 48,42 L 45,42 L 45,44 L 35,44 L 35,42 L 32,42 L 35,38 L 35,28 Z"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Windows -->
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <EllipseGeometry Center="24,30" RadiusX="2" RadiusY="2"/>
                            <EllipseGeometry Center="40,30" RadiusX="2" RadiusY="2"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         MODE 3 / AGGRESSIVE — three rockets
         ============================================================ -->
    <DrawingImage x:Key="IconModeAggressive">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="{StaticResource IconShadowBrush}" Geometry="{StaticResource IconShadowGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}" Geometry="{StaticResource IconTileGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconHighlightBrush}" Geometry="{StaticResource IconHighlightGeometry}"/>
                <!-- Flames (left, center, right) -->
                <GeometryDrawing Brush="#FFFFE066">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <PathGeometry Figures="M 16,44 L 18.5,48 L 21,44 Z"/>
                            <PathGeometry Figures="M 29.5,44 L 32,48 L 34.5,44 Z"/>
                            <PathGeometry Figures="M 43,44 L 45.5,48 L 48,44 Z"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Rocket bodies — center one slightly larger / forward -->
                <GeometryDrawing Brush="{StaticResource IconGlyphBrush}">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <!-- Left rocket centered at (18.5, 32) -->
                            <PathGeometry Figures="M 18.5,20 L 22,28 L 22,38 L 24,40 L 22,40 L 22,42 L 15,42 L 15,40 L 13,40 L 15,38 L 15,28 Z"/>
                            <!-- Center rocket centered at (32, 30) — slightly forward -->
                            <PathGeometry Figures="M 32,16 L 36,26 L 36,38 L 38.5,40 L 36,40 L 36,42 L 28,42 L 28,40 L 25.5,40 L 28,38 L 28,26 Z"/>
                            <!-- Right rocket centered at (45.5, 32) -->
                            <PathGeometry Figures="M 45.5,20 L 49,28 L 49,38 L 51,40 L 49,40 L 49,42 L 42,42 L 42,40 L 40,40 L 42,38 L 42,28 Z"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Windows -->
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <EllipseGeometry Center="18.5,31" RadiusX="1.5" RadiusY="1.5"/>
                            <EllipseGeometry Center="32,28" RadiusX="2" RadiusY="2"/>
                            <EllipseGeometry Center="45.5,31" RadiusX="1.5" RadiusY="1.5"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- ============================================================
         RESTART (reboot circular arrow)
         ============================================================ -->
    <DrawingImage x:Key="IconRestart">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="{StaticResource IconShadowBrush}" Geometry="{StaticResource IconShadowGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconBaseBrush}" Geometry="{StaticResource IconTileGeometry}"/>
                <GeometryDrawing Brush="{StaticResource IconHighlightBrush}" Geometry="{StaticResource IconHighlightGeometry}"/>
                <!-- Almost-full circle -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource IconGlyphBrush}" Thickness="3.5" StartLineCap="Round" EndLineCap="Round"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 44,32 A 12,12 0 1 1 32,20"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Arrow head -->
                <GeometryDrawing Brush="{StaticResource IconGlyphBrush}">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M 32,15 L 26,20 L 32,25 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

</ResourceDictionary>
