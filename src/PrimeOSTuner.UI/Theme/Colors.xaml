<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Dark palette — calm surfaces, soft translucent strokes. v0.4 restyle. -->

    <!-- Backgrounds: deep base, gentle elevation steps -->
    <Color x:Key="Bg0">#131315</Color>
    <Color x:Key="Bg1">#1C1C20</Color>
    <Color x:Key="Bg2">#232327</Color>
    <Color x:Key="Bg3">#2C2C32</Color>

    <!-- Strokes: translucent white so edges read softly on any surface -->
    <Color x:Key="Stroke">#16FFFFFF</Color>
    <Color x:Key="StrokeSoft">#0EFFFFFF</Color>

    <!-- Text — cool off-white, clear hierarchy -->
    <Color x:Key="Text0">#F3F3F6</Color>
    <Color x:Key="Text1">#C6C6CF</Color>
    <Color x:Key="Text2">#8E8E9A</Color>
    <Color x:Key="Text3">#5F5F69</Color>
    <Color x:Key="Text4">#45454D</Color>

    <!-- Accent: hot pink → orange. The signature identity — kept. -->
    <Color x:Key="AccentPink">#F7416B</Color>
    <Color x:Key="AccentOrange">#FFA01F</Color>
    <Color x:Key="Accent">#F77254</Color>          <!-- middle (coral), used as solid accent -->
    <Color x:Key="AccentHover">#FF8A6A</Color>
    <Color x:Key="AccentPressed">#D63B5A</Color>

    <!-- Status -->
    <Color x:Key="Good">#3ECF8E</Color>
    <Color x:Key="Warn">#FFB84D</Color>
    <Color x:Key="Danger">#FF6B6B</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="Bg0Brush"        Color="{StaticResource Bg0}"/>
    <SolidColorBrush x:Key="Bg1Brush"        Color="{StaticResource Bg1}"/>
    <SolidColorBrush x:Key="Bg2Brush"        Color="{StaticResource Bg2}"/>
    <SolidColorBrush x:Key="Bg3Brush"        Color="{StaticResource Bg3}"/>
    <SolidColorBrush x:Key="StrokeBrush"     Color="{StaticResource Stroke}"/>
    <SolidColorBrush x:Key="StrokeSoftBrush" Color="{StaticResource StrokeSoft}"/>

    <SolidColorBrush x:Key="Text0Brush"      Color="{StaticResource Text0}"/>
    <SolidColorBrush x:Key="Text1Brush"      Color="{StaticResource Text1}"/>
    <SolidColorBrush x:Key="Text2Brush"      Color="{StaticResource Text2}"/>
    <SolidColorBrush x:Key="Text3Brush"      Color="{StaticResource Text3}"/>
    <SolidColorBrush x:Key="Text4Brush"      Color="{StaticResource Text4}"/>

    <SolidColorBrush x:Key="AccentBrush"        Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="AccentHoverBrush"   Color="{StaticResource AccentHover}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressed}"/>

    <SolidColorBrush x:Key="GoodBrush"   Color="{StaticResource Good}"/>
    <SolidColorBrush x:Key="WarnBrush"   Color="{StaticResource Warn}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}"/>

    <!-- Pink → orange horizontal gradient. The signature accent of the app. -->
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="{StaticResource AccentPink}"   Offset="0"/>
        <GradientStop Color="{StaticResource Accent}"       Offset="0.55"/>
        <GradientStop Color="{StaticResource AccentOrange}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentHoverGradientBrush" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#FF6388" Offset="0"/>
        <GradientStop Color="#FF8A6A" Offset="0.55"/>
        <GradientStop Color="#FFB142" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentPressedGradientBrush" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#D6315A" Offset="0"/>
        <GradientStop Color="#D2604A" Offset="0.55"/>
        <GradientStop Color="#E08512" Offset="1"/>
    </LinearGradientBrush>
</ResourceDictionary>
