<UserControl x:Class="PrimeOSTuner.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,16,0">
        <StackPanel Margin="0,0,0,32">

            <TextBlock Text="Settings" Style="{StaticResource HeaderText}" Margin="0,0,0,8"/>
            <TextBlock Text="App behavior and automation"
                       Style="{StaticResource SubHeaderText}" Margin="0,0,0,24"/>

            <!-- ===================================== Memory trim ===================================== -->
            <TextBlock Text="MEMORY TRIM" Style="{StaticResource SectionLabel}"/>
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,18">
                <StackPanel>
                    <!-- Auto on interval -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Trim on a timer" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="Trim every N minutes. Asks each app to release idle memory pages; mainly helps memory-leaky games, otherwise neutral."
                                       Foreground="{StaticResource Text2Brush}" FontSize="12" Margin="0,2,0,0"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"
                                      IsChecked="{Binding RamAutoOptimizeOnInterval, Mode=TwoWay}"
                                      VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,8,0,0" IsEnabled="{Binding RamAutoOptimizeOnInterval}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Run every" Foreground="{StaticResource Text2Brush}"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBox Grid.Column="1" Text="{Binding RamAutoIntervalMinutes, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Grid.Column="2" Text="minutes" Foreground="{StaticResource Text2Brush}"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </Grid>

                    <!-- divider -->
                    <Border Background="{StaticResource StrokeBrush}" Height="1" Margin="0,16,0,16"/>

                    <!-- Auto on threshold -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Trim when memory is high" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="Trim when RAM usage rises above a set percentage."
                                       Foreground="{StaticResource Text2Brush}" FontSize="12" Margin="0,2,0,0"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"
                                      IsChecked="{Binding RamAutoOptimizeOnThreshold, Mode=TwoWay}"
                                      VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,8,0,0" IsEnabled="{Binding RamAutoOptimizeOnThreshold}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Trigger when above" Foreground="{StaticResource Text2Brush}"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBox Grid.Column="1" Text="{Binding RamThresholdPercent, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Grid.Column="2" Text="% RAM used" Foreground="{StaticResource Text2Brush}"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </Grid>

                    <!-- divider -->
                    <Border Background="{StaticResource StrokeBrush}" Height="1" Margin="0,16,0,16"/>

                    <!-- Manual run -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Trim memory now" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock x:Name="RamStatus" Text="{Binding RamStatusMessage}"
                                       Foreground="{StaticResource Text3Brush}"
                                       FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Trim now" Click="OptimizeNowClick"
                                VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===================================== General ===================================== -->
            <TextBlock Text="GENERAL" Style="{StaticResource SectionLabel}"/>
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,18">
                <StackPanel>
                    <!-- Start at boot -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Start at boot" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="Run Crustcut automatically when Windows starts."
                                       Foreground="{StaticResource Text2Brush}" FontSize="12" Margin="0,2,0,0"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"
                                      IsChecked="{Binding StartAtBoot, Mode=TwoWay}"
                                      VerticalAlignment="Center"/>
                    </Grid>

                    <Border Background="{StaticResource StrokeBrush}" Height="1" Margin="0,16,0,16"/>

                    <!-- Start minimized — saved but tray icon comes in v0.3 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Start minimized to system tray" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="Launch into the system tray instead of opening the window."
                                       Foreground="{StaticResource Text2Brush}" FontSize="12" Margin="0,2,0,0"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"
                                      IsChecked="{Binding StartMinimized, Mode=TwoWay}"
                                      VerticalAlignment="Center"/>
                    </Grid>

                    <Border Background="{StaticResource StrokeBrush}" Height="1" Margin="0,16,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Minimize to tray on close" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="Click X to hide to the tray instead of exiting. Use the tray menu to fully exit."
                                       Foreground="{StaticResource Text2Brush}" FontSize="12" Margin="0,2,0,0"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"
                                      IsChecked="{Binding MinimizeToTrayOnClose, Mode=TwoWay}"
                                      VerticalAlignment="Center"/>
                    </Grid>

                    <Border Background="{StaticResource StrokeBrush}" Height="1" Margin="0,16,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Notifications" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="Show a Windows notification when an optimization or RAM cleanup runs."
                                       Foreground="{StaticResource Text2Brush}" FontSize="12" Margin="0,2,0,0"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"
                                      IsChecked="{Binding NotificationsEnabled, Mode=TwoWay}"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ================================ Performance overlay ================================ -->
            <TextBlock Text="PERFORMANCE OVERLAY" Style="{StaticResource SectionLabel}"/>
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,18">
                <StackPanel>
                    <!-- Master toggle -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="In-game performance overlay" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="A clean, see-through on-screen display of your live CPU / GPU / RAM / VRAM while you play — powered by Sentinel."
                                       Foreground="{StaticResource Text2Brush}" FontSize="12"
                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"
                                      IsChecked="{Binding OverlayEnabled, Mode=TwoWay}"
                                      VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Everything below is only relevant when the overlay is on. -->
                    <StackPanel IsEnabled="{Binding OverlayEnabled}">
                        <Border Background="{StaticResource StrokeBrush}" Height="1" Margin="0,16,0,16"/>

                        <!-- Reposition + hotkey -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Position" FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock FontSize="12" Foreground="{StaticResource Text2Brush}"
                                           TextWrapping="Wrap" Margin="0,2,0,0">
                                    Press <Run Text="Ctrl + Shift + O" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                                    anytime (even mid-game) to enter edit mode, drag it where you want, then press it again to lock.
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Reposition"
                                    Command="{Binding RepositionOverlayCommand}"
                                    VerticalAlignment="Center"/>
                        </Grid>

                        <Border Background="{StaticResource StrokeBrush}" Height="1" Margin="0,16,0,16"/>

                        <!-- Only in game -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Only show while a game is running" FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock Text="Hide the overlay on the desktop; show it only when a detected game is open."
                                           Foreground="{StaticResource Text2Brush}" FontSize="12" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"
                                          IsChecked="{Binding OverlayOnlyInGame, Mode=TwoWay}"
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Border Background="{StaticResource StrokeBrush}" Height="1" Margin="0,16,0,16"/>

                        <!-- Metrics -->
                        <TextBlock Text="What to show" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                        <WrapPanel>
                            <CheckBox Content="FPS"     Foreground="{StaticResource Text0Brush}" Margin="0,0,20,8"
                                      IsChecked="{Binding OverlayShowFps, Mode=TwoWay}"/>
                            <CheckBox Content="CPU"     Foreground="{StaticResource Text0Brush}" Margin="0,0,20,8"
                                      IsChecked="{Binding OverlayShowCpu, Mode=TwoWay}"/>
                            <CheckBox Content="GPU"     Foreground="{StaticResource Text0Brush}" Margin="0,0,20,8"
                                      IsChecked="{Binding OverlayShowGpu, Mode=TwoWay}"/>
                            <CheckBox Content="RAM"     Foreground="{StaticResource Text0Brush}" Margin="0,0,20,8"
                                      IsChecked="{Binding OverlayShowRam, Mode=TwoWay}"/>
                            <CheckBox Content="VRAM"    Foreground="{StaticResource Text0Brush}" Margin="0,0,20,8"
                                      IsChecked="{Binding OverlayShowVram, Mode=TwoWay}"/>
                            <CheckBox Content="Network" Foreground="{StaticResource Text0Brush}" Margin="0,0,20,8"
                                      IsChecked="{Binding OverlayShowNet, Mode=TwoWay}"/>
                        </WrapPanel>

                        <Border Background="{StaticResource StrokeBrush}" Height="1" Margin="0,8,0,16"/>

                        <!-- Size -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Text size" Foreground="{StaticResource Text2Brush}"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Slider Grid.Column="1" Minimum="0.8" Maximum="1.6" TickFrequency="0.1"
                                    IsSnapToTickEnabled="True" VerticalAlignment="Center"
                                    Value="{Binding OverlayScale, Mode=TwoWay}"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
