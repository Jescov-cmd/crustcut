<UserControl x:Class="PrimeOSTuner.UI.Views.MemoryPriorityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mem="clr-namespace:PrimeOSTuner.Core.Memory;assembly=PrimeOSTuner.Core">
    <UserControl.Resources>
        <!-- Priority enum values in low→high order (declaration order in C# has BelowNormal last) -->
        <x:Array x:Key="PriorityValues" Type="{x:Type mem:PriorityLevel}">
            <mem:PriorityLevel>BelowNormal</mem:PriorityLevel>
            <mem:PriorityLevel>Normal</mem:PriorityLevel>
            <mem:PriorityLevel>AboveNormal</mem:PriorityLevel>
            <mem:PriorityLevel>High</mem:PriorityLevel>
        </x:Array>

        <!-- ListBoxItem styled as a horizontal pill — replaces the old ComboBox -->
        <Style x:Key="PriorityPillItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource Text2Brush}"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bg"
                                CornerRadius="6"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                Margin="2,0"
                                Padding="12,6">
                            <TextBlock Text="{Binding Converter={StaticResource PriorityShortLabel}}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#15FFFFFF"/>
                                <Setter Property="Foreground" Value="{StaticResource Text0Brush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentGradientBrush}"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="#1A1A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListBox styled as a segmented control track -->
        <Style x:Key="PriorityPillsListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource Bg1Brush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource PriorityPillItemStyle}"/>
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1"/>
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Subtle Remove button — outline only, danger-tinted on hover -->
        <Style x:Key="RemoveLinkStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource Text3Brush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#33FF6A6A"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="#FF6A6A"/>
                                <Setter Property="Foreground" Value="#FFB0B0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,16,0">
        <StackPanel Margin="0,0,0,32">
            <TextBlock Text="Memory Priority" Style="{StaticResource HeaderText}" Margin="0,0,0,8"/>
            <TextBlock Text="Pin per-app CPU priority and protect important apps from RAM cleanups."
                       Style="{StaticResource SubHeaderText}" Margin="0,0,0,24"/>

            <!-- Toolbar: filter chips on the left, actions on the right -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <RadioButton GroupName="MpFilter" Content="All"
                                 IsChecked="True" Click="FilterAllClick" Margin="0,0,6,0"/>
                    <RadioButton GroupName="MpFilter" Content="Games"
                                 Click="FilterGamesClick" Margin="0,0,6,0"/>
                    <RadioButton GroupName="MpFilter" Content="Apps"
                                 Click="FilterAppsClick"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Click="RescanClick"
                            ToolTip="Add any newly-running user apps to the list."
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource IconRestart}" Width="14" Height="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Re-scan" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Content="+ Add App" Click="AddAppClick" Margin="0,0,8,0"/>
                    <ToggleButton x:Name="MultiSelectToggle"
                                  Click="MultiSelectToggleClick"
                                  Margin="0,0,8,0"
                                  ToolTip="Select multiple rows, then apply a bulk action.">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Foreground" Value="{StaticResource Text0Brush}"/>
                                <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Padding" Value="12,6"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="bg"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="{StaticResource Bg3Brush}"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentGradientBrush}"/>
                                                    <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="#1A1A1A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ToggleButton.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="☑" FontSize="13" Margin="0,0,6,0"/>
                            <TextBlock Text="Multi-select" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>
                    <Button Click="ApplyRecommendedClick"
                            Style="{StaticResource PrimaryActionButton}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource IconLightning}" Width="14" Height="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Apply Recommended" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Bulk action bar — visible only in multi-select mode -->
            <Border x:Name="BulkBar"
                    Visibility="{Binding MultiSelectMode, Converter={StaticResource BoolToVisibility}}"
                    Background="{StaticResource Bg2Brush}"
                    BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                    CornerRadius="10" Padding="14,10" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="SelectionCountText"
                               Text="0 selected"
                               FontWeight="SemiBold" FontSize="13"
                               Foreground="{StaticResource Text0Brush}"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Set priority:" VerticalAlignment="Center"
                                   Foreground="{StaticResource Text2Brush}" FontSize="12" Margin="0,0,8,0"/>
                        <Button Content="Below" Tag="BelowNormal" Click="BulkPriorityClick" Margin="0,0,4,0" Padding="10,5"/>
                        <Button Content="Normal" Tag="Normal" Click="BulkPriorityClick" Margin="0,0,4,0" Padding="10,5"/>
                        <Button Content="Above" Tag="AboveNormal" Click="BulkPriorityClick" Margin="0,0,4,0" Padding="10,5"/>
                        <Button Content="High" Tag="High" Click="BulkPriorityClick" Margin="0,0,16,0" Padding="10,5"/>
                        <Button Content="Protect" Click="BulkProtectClick" Margin="0,0,4,0" Padding="10,5"
                                ToolTip="Click to apply Protect to every selected row. Click again to remove it."/>
                        <Button Content="Booster" Click="BulkBoosterClick" Margin="0,0,12,0" Padding="10,5"
                                ToolTip="Click to apply Booster to every selected row. Click again to remove it."/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="Apply"
                            Style="{StaticResource PrimaryActionButton}"
                            Click="DiscardSelectionClick"
                            VerticalAlignment="Center"
                            ToolTip="Finish multi-select and return to normal view."/>
                </Grid>
            </Border>

            <!-- Single list card with rows separated by subtle dividers -->
            <Border Style="{StaticResource CardBorder}" Padding="0">
                <ItemsControl x:Name="RuleList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="20,14"
                                    BorderBrush="#22FFFFFF"
                                    BorderThickness="0,0,0,1"
                                    PreviewMouseLeftButtonDown="Row_PreviewMouseLeftButtonDown"
                                    MouseEnter="Row_MouseEnter">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#0DFFFFFF"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="#33F77254"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Selection checkbox — only visible in multi-select mode -->
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              VerticalAlignment="Center" Margin="0,0,16,0"
                                              IsHitTestVisible="False"
                                              Visibility="{Binding DataContext.MultiSelectMode, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Converter={StaticResource BoolToVisibility}}"/>

                                    <!-- Type icon -->
                                    <Image Grid.Column="1"
                                           Source="{StaticResource IconGameLibrary}"
                                           Width="24" Height="24" Margin="0,0,16,0" VerticalAlignment="Center"
                                           Visibility="{Binding IsGame, Converter={StaticResource BoolToVisibility}}"/>
                                    <Image Grid.Column="1"
                                           Source="{StaticResource IconOptimize}"
                                           Width="24" Height="24" Margin="0,0,16,0" VerticalAlignment="Center"
                                           Visibility="{Binding IsGame, Converter={StaticResource InverseBoolToVisibility}, FallbackValue=Collapsed}"/>

                                    <!-- Name + exe -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="SemiBold" FontSize="14"
                                                   Foreground="{StaticResource Text0Brush}"/>
                                        <TextBlock Text="{Binding ExeName}"
                                                   Foreground="{StaticResource Text3Brush}"
                                                   FontSize="11" Margin="0,2,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <!-- Priority pills — disabled in multi-select so drag-select doesn't fight the inner ListBox -->
                                    <ListBox Grid.Column="3"
                                             Style="{StaticResource PriorityPillsListBoxStyle}"
                                             ItemsSource="{StaticResource PriorityValues}"
                                             SelectedItem="{Binding Priority, Mode=TwoWay}"
                                             SelectionChanged="RuleChanged"
                                             VerticalAlignment="Center"
                                             Margin="12,0"
                                             Width="340"
                                             IsEnabled="{Binding DataContext.MultiSelectMode, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Converter={StaticResource InverseBoolConverter}}"/>

                                    <!-- Inline checkboxes -->
                                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,12,0"
                                                IsEnabled="{Binding DataContext.MultiSelectMode, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Converter={StaticResource InverseBoolConverter}}">
                                        <CheckBox Content="Protect" Margin="8,0"
                                                  ToolTip="Skip this app when running RAM cleanups"
                                                  IsChecked="{Binding ProtectFromRamCleanup, Mode=TwoWay}"
                                                  Click="RuleChanged"/>
                                        <CheckBox Content="Booster" Margin="8,0"
                                                  ToolTip="Game Booster: safe RAM cleanup 2s after launch"
                                                  IsChecked="{Binding GameBooster, Mode=TwoWay}"
                                                  Click="RuleChanged"/>
                                    </StackPanel>

                                    <!-- Remove -->
                                    <Button Grid.Column="5"
                                            Content="Remove"
                                            Style="{StaticResource RemoveLinkStyle}"
                                            Click="RemoveClick" Tag="{Binding}"
                                            VerticalAlignment="Center"
                                            IsEnabled="{Binding DataContext.MultiSelectMode, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Converter={StaticResource InverseBoolConverter}}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
