<UserControl x:Class="PrimeOSTuner.UI.Views.OptimizeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- Tile that gets a gradient border when its tweak is applied -->
        <Style x:Key="OptimizerTile" TargetType="Border" BasedOn="{StaticResource CardBorder}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsApplied}" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentGradientBrush}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Filter chip: pill RadioButton with accent-gradient fill when checked -->
        <Style x:Key="FilterChipStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource Text2Brush}"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bg"
                                CornerRadius="6"
                                Background="{StaticResource Bg2Brush}"
                                BorderBrush="{StaticResource StrokeBrush}"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource Bg3Brush}"/>
                                <Setter Property="Foreground" Value="{StaticResource Text0Brush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentGradientBrush}"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="bg" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#F77254" BlurRadius="14" ShadowDepth="0" Opacity="0.65"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="#1A1A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section header for the Standard / Advanced groupings on the tile list -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource Text3Brush}"/>
            <Setter Property="Margin" Value="0,8,0,10"/>
        </Style>

        <!-- Shared tile template used by both the Standard and Advanced lists. -->
        <DataTemplate x:Key="TweakTileTemplate">
            <Border Style="{StaticResource OptimizerTile}"
                    Width="280" Height="180"
                    Margin="0,0,12,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Status pills row: Active/Off + (optional) Reboot + (optional) Caution -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Border HorizontalAlignment="Left"
                                CornerRadius="6" Padding="8,3"
                                Background="{StaticResource Bg2Brush}"
                                BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="ToolTip" Value="This tweak is not currently applied. Toggle the switch on to apply it."/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsApplied}" Value="True">
                                            <Setter Property="ToolTip" Value="This tweak is currently applied. Toggle the switch off to revert it."/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="10" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="OFF"/>
                                        <Setter Property="Foreground" Value="{StaticResource Text3Brush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsApplied}" Value="True">
                                                <Setter Property="Text" Value="ACTIVE"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                        <!-- "REBOOT" pill — only visible when the tweak's RequiresReboot flag is true -->
                        <Border Margin="6,0,0,0"
                                CornerRadius="6" Padding="8,3"
                                BorderThickness="1"
                                BorderBrush="{StaticResource AccentBrush}"
                                Background="#1F1916"
                                Visibility="{Binding Tweak.RequiresReboot, Converter={StaticResource BoolToVisibility}}"
                                ToolTip="Windows needs to restart for this change to fully take effect.">
                            <TextBlock Text="REBOOT" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </Border>
                        <!-- "CAUTION" pill — only visible when the tweak has a RiskNote -->
                        <Border Margin="6,0,0,0"
                                CornerRadius="6" Padding="8,3"
                                BorderThickness="1"
                                BorderBrush="#FFA01F"
                                Background="#1F1916"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasRisk, Converter={StaticResource BoolToVisibility}}"
                                ToolTip="{Binding RiskNote}">
                            <TextBlock Text="⚠ CAUTION" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#FFD580"/>
                        </Border>
                    </StackPanel>

                    <!-- Title + description -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,12,0,0">
                        <TextBlock Text="{Binding Tweak.DisplayName}"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="15" FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding Tweak.Description}"
                                   ToolTip="{Binding Tweak.Description}"
                                   Foreground="{StaticResource Text2Brush}"
                                   FontSize="11" Margin="0,4,0,0"
                                   TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                   MaxHeight="36"/>
                    </StackPanel>

                    <!-- Toggle bottom-right -->
                    <ToggleButton Grid.Row="2"
                                  Style="{StaticResource ToggleSwitchStyle}"
                                  IsChecked="{Binding IsApplied, Mode=TwoWay}"
                                  Tag="{Binding}"
                                  Click="ToggleClick"
                                  HorizontalAlignment="Right"
                                  Margin="0,12,0,0"/>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer x:Name="PageScroller"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled" Padding="0,0,16,0">
        <StackPanel Margin="0,0,0,32">
            <TextBlock Text="Optimize" Style="{StaticResource HeaderText}" Margin="0,0,0,8"/>
            <TextBlock Text="Toggle each tile on or off. The tile lights up while a tweak is active."
                       Style="{StaticResource SubHeaderText}" Margin="0,0,0,20"/>

            <!-- Reboot-required banner: shown after a tweak whose change needs a restart is toggled -->
            <Border x:Name="RebootBanner" Visibility="Collapsed"
                    BorderBrush="{StaticResource AccentGradientBrush}"
                    BorderThickness="2" CornerRadius="10"
                    Background="#221A14" Padding="16,12" Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Reboot required"
                                   FontWeight="Bold" FontSize="14"
                                   Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock x:Name="RebootBannerDetail"
                                   Foreground="{StaticResource Text2Brush}"
                                   FontSize="12" Margin="0,2,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Restart now"
                            Style="{StaticResource PrimaryActionButton}"
                            Click="RestartNowClick" Margin="12,0,8,0"/>
                    <Button Grid.Column="2" Content="Later"
                            Click="DismissRebootBannerClick"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Search box -->
            <Border CornerRadius="8" Background="{StaticResource Bg2Brush}"
                    BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1"
                    Padding="12,6" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Path Grid.Column="0" VerticalAlignment="Center" Width="14" Height="14"
                          Stretch="Uniform"
                          Stroke="{StaticResource Text3Brush}" StrokeThickness="1.6"
                          Data="M 10 10 m -6 0 a 6 6 0 1 0 12 0 a 6 6 0 1 0 -12 0 M 14 14 L 18 18"/>
                    <TextBox x:Name="SearchBox" Grid.Column="1"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource Text0Brush}"
                             CaretBrush="{StaticResource AccentBrush}"
                             FontSize="13" VerticalAlignment="Center"
                             Margin="10,0,0,0"
                             TextChanged="SearchBox_TextChanged"/>
                    <TextBlock Grid.Column="1" IsHitTestVisible="False"
                               Text="Search tweaks…"
                               Foreground="{StaticResource Text4Brush}"
                               FontSize="13" VerticalAlignment="Center"
                               Margin="10,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Button Grid.Column="2" x:Name="ClearSearchBtn"
                            Content="×" Width="22" Height="22"
                            Padding="0" FontSize="16" FontWeight="Bold"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource Text3Brush}" Cursor="Hand"
                            VerticalAlignment="Center"
                            Click="ClearSearchClick"
                            Visibility="Collapsed"/>
                </Grid>
            </Border>

            <!-- Filter chips -->
            <ItemsControl x:Name="FilterChips" Margin="0,0,0,18">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <RadioButton GroupName="OptFilter"
                                     Style="{StaticResource FilterChipStyle}"
                                     Content="{Binding Label}"
                                     IsChecked="{Binding IsActive, Mode=TwoWay}"
                                     Tag="{Binding Key}"
                                     Click="ChipClick"
                                     Margin="0,0,8,0"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Standard tweaks: no reboot, no caution. The "easy ones." -->
            <TextBlock x:Name="StandardHeader"
                       Text="STANDARD"
                       Style="{StaticResource SectionHeaderStyle}"/>
            <ItemsControl x:Name="StandardTweakList"
                          ItemTemplate="{StaticResource TweakTileTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <!-- Advanced tweaks: anything that needs reboot or has a caution flag. -->
            <TextBlock x:Name="AdvancedHeader"
                       Text="ADVANCED &amp; CAUTION"
                       Style="{StaticResource SectionHeaderStyle}"
                       Margin="0,16,0,10"/>
            <ItemsControl x:Name="AdvancedTweakList"
                          ItemTemplate="{StaticResource TweakTileTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
