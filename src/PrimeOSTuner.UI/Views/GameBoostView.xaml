<UserControl x:Class="PrimeOSTuner.UI.Views.GameBoostView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- Gem (rotated rounded square). Used by all three mode cards. -->
        <Style x:Key="Gem" TargetType="Rectangle">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="RadiusX" Value="2.5"/>
            <Setter Property="RadiusY" Value="2.5"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Margin" Value="3,4,0,4"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <RotateTransform Angle="45"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,16,0">
        <StackPanel Margin="0,0,0,32">
            <TextBlock Text="Game Boost" Style="{StaticResource HeaderText}" Margin="0,0,0,8"/>
            <TextBlock Text="Toggle a profile on or off"
                       Style="{StaticResource SubHeaderText}" Margin="0,0,0,24"/>

            <UniformGrid Columns="3" Margin="0,0,0,18">
                <!-- Basic -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                    <StackPanel>
                        <!-- Gem Tier 1 — calm green, single gem -->
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="0,0,0,8">
                            <Rectangle x:Name="GemB1" Style="{StaticResource Gem}" Fill="#6EE7A8">
                                <Rectangle.Effect>
                                    <DropShadowEffect x:Name="GemB1Glow" Color="#6EE7A8" ShadowDepth="0" BlurRadius="6" Opacity="0.85"/>
                                </Rectangle.Effect>
                                <Rectangle.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetName="GemB1Glow" Storyboard.TargetProperty="BlurRadius"
                                                                 From="6" To="16" Duration="0:0:0.9"/>
                                                <DoubleAnimation Storyboard.TargetName="GemB1Glow" Storyboard.TargetProperty="Opacity"
                                                                 From="0.7" To="1" Duration="0:0:0.9"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Rectangle.Triggers>
                            </Rectangle>
                        </StackPanel>
                        <TextBlock Text="BASIC MODE" Style="{StaticResource SectionLabel}" Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="Lightweight gaming preset"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="18" FontWeight="SemiBold" Margin="0,4,0,8"/>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{StaticResource Text2Brush}"
                                   FontSize="12" Margin="0,0,0,18">
                            Game Mode + mouse acceleration off + High-Performance power plan. Safe for most systems.
                        </TextBlock>
                        <Border Background="{StaticResource StrokeBrush}" Height="1" Margin="0,0,0,14"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Enable" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="1" x:Name="BasicToggle"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          IsChecked="{Binding IsBasicActive, Mode=TwoWay}"
                                          Click="BasicToggleClick"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Performance -->
                <Border Style="{StaticResource CardBorder}" Margin="4,0">
                    <StackPanel>
                        <!-- Gem Tier 2 — intense amber, two gems -->
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="0,0,0,8">
                            <Rectangle x:Name="GemP2" Style="{StaticResource Gem}" Fill="#F5C66B">
                                <Rectangle.Effect>
                                    <DropShadowEffect x:Name="GemP2Glow" Color="#F5C66B" ShadowDepth="0" BlurRadius="6" Opacity="0.85"/>
                                </Rectangle.Effect>
                                <Rectangle.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True" BeginTime="0:0:0.15">
                                                <DoubleAnimation Storyboard.TargetName="GemP2Glow" Storyboard.TargetProperty="BlurRadius"
                                                                 From="6" To="16" Duration="0:0:0.9"/>
                                                <DoubleAnimation Storyboard.TargetName="GemP2Glow" Storyboard.TargetProperty="Opacity"
                                                                 From="0.7" To="1" Duration="0:0:0.9"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Rectangle.Triggers>
                            </Rectangle>
                            <Rectangle x:Name="GemP1" Style="{StaticResource Gem}" Fill="#F5C66B">
                                <Rectangle.Effect>
                                    <DropShadowEffect x:Name="GemP1Glow" Color="#F5C66B" ShadowDepth="0" BlurRadius="6" Opacity="0.85"/>
                                </Rectangle.Effect>
                                <Rectangle.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetName="GemP1Glow" Storyboard.TargetProperty="BlurRadius"
                                                                 From="6" To="16" Duration="0:0:0.9"/>
                                                <DoubleAnimation Storyboard.TargetName="GemP1Glow" Storyboard.TargetProperty="Opacity"
                                                                 From="0.7" To="1" Duration="0:0:0.9"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Rectangle.Triggers>
                            </Rectangle>
                        </StackPanel>
                        <TextBlock Text="PERFORMANCE MODE" Style="{StaticResource SectionLabel}" Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="Maximum tuning preset"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="18" FontWeight="SemiBold" Margin="0,4,0,8"/>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{StaticResource Text2Brush}"
                                   FontSize="12" Margin="0,0,0,18">
                            Everything in Basic + timer resolution + hardware GPU scheduling + multimedia priority maxed + telemetry trimmed.
                        </TextBlock>
                        <Border Background="{StaticResource StrokeBrush}" Height="1" Margin="0,0,0,14"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Enable" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="1" x:Name="PerformanceToggle"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          IsChecked="{Binding IsPerformanceActive, Mode=TwoWay}"
                                          Click="PerformanceToggleClick"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Aggressive -->
                <Border Style="{StaticResource CardBorder}" Margin="8,0,0,0">
                    <StackPanel>
                        <!-- Gem Tier 3 — extreme red, three gems -->
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="0,0,0,8">
                            <Rectangle x:Name="GemA3" Style="{StaticResource Gem}" Fill="#FF6A6A">
                                <Rectangle.Effect>
                                    <DropShadowEffect x:Name="GemA3Glow" Color="#FF6A6A" ShadowDepth="0" BlurRadius="6" Opacity="0.85"/>
                                </Rectangle.Effect>
                                <Rectangle.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True" BeginTime="0:0:0.30">
                                                <DoubleAnimation Storyboard.TargetName="GemA3Glow" Storyboard.TargetProperty="BlurRadius"
                                                                 From="6" To="16" Duration="0:0:0.9"/>
                                                <DoubleAnimation Storyboard.TargetName="GemA3Glow" Storyboard.TargetProperty="Opacity"
                                                                 From="0.7" To="1" Duration="0:0:0.9"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Rectangle.Triggers>
                            </Rectangle>
                            <Rectangle x:Name="GemA2" Style="{StaticResource Gem}" Fill="#FF6A6A">
                                <Rectangle.Effect>
                                    <DropShadowEffect x:Name="GemA2Glow" Color="#FF6A6A" ShadowDepth="0" BlurRadius="6" Opacity="0.85"/>
                                </Rectangle.Effect>
                                <Rectangle.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True" BeginTime="0:0:0.15">
                                                <DoubleAnimation Storyboard.TargetName="GemA2Glow" Storyboard.TargetProperty="BlurRadius"
                                                                 From="6" To="16" Duration="0:0:0.9"/>
                                                <DoubleAnimation Storyboard.TargetName="GemA2Glow" Storyboard.TargetProperty="Opacity"
                                                                 From="0.7" To="1" Duration="0:0:0.9"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Rectangle.Triggers>
                            </Rectangle>
                            <Rectangle x:Name="GemA1" Style="{StaticResource Gem}" Fill="#FF6A6A">
                                <Rectangle.Effect>
                                    <DropShadowEffect x:Name="GemA1Glow" Color="#FF6A6A" ShadowDepth="0" BlurRadius="6" Opacity="0.85"/>
                                </Rectangle.Effect>
                                <Rectangle.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetName="GemA1Glow" Storyboard.TargetProperty="BlurRadius"
                                                                 From="6" To="16" Duration="0:0:0.9"/>
                                                <DoubleAnimation Storyboard.TargetName="GemA1Glow" Storyboard.TargetProperty="Opacity"
                                                                 From="0.7" To="1" Duration="0:0:0.9"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Rectangle.Triggers>
                            </Rectangle>
                        </StackPanel>
                        <TextBlock Text="AGGRESSIVE MODE" Style="{StaticResource SectionLabel}" Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="All-out tuning preset"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="18" FontWeight="SemiBold" Margin="0,4,0,8"/>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{StaticResource Text2Brush}"
                                   FontSize="12" Margin="0,0,0,18">
                            Everything in Performance + Cortana off + modern standby off + hibernation off. May break some apps.
                        </TextBlock>
                        <Border Background="{StaticResource StrokeBrush}" Height="1" Margin="0,0,0,14"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Enable" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="1" x:Name="AggressiveToggle"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          IsChecked="{Binding IsAggressiveActive, Mode=TwoWay}"
                                          Click="AggressiveToggleClick"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <TextBlock Text="STATUS" Style="{StaticResource SectionLabel}"/>
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,18">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource Text0Brush}"
                           FontSize="13" TextWrapping="Wrap"/>
            </Border>

            <TextBlock Text="SUSPENDED WHILE GAMING" Style="{StaticResource SectionLabel}"/>
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,18">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap"
                               Foreground="{StaticResource Text2Brush}"
                               FontSize="12" Margin="0,0,0,8">
                        When a game from your Library launches, these background apps are frozen (their processes are paused, not killed) and resumed when the game exits. Steam and browsers are deliberately excluded.
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding SuspendedApps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}"
                                               FontSize="13" Foreground="{StaticResource Text0Brush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Pid, StringFormat='PID {0}'}"
                                               FontSize="11" Foreground="{StaticResource Text3Brush}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <TextBlock Foreground="{StaticResource Text3Brush}"
                       FontSize="12" TextWrapping="Wrap">
                Tip: To attach a profile to a specific game so it auto-applies on launch, go to the Library tab and pick a profile from the dropdown on each game tile.
            </TextBlock>
        </StackPanel>
    </ScrollViewer>
</UserControl>
