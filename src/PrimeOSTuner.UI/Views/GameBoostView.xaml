<UserControl x:Class="PrimeOSTuner.UI.Views.GameBoostView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,16,0">
        <StackPanel Margin="0,0,0,32">
            <TextBlock Text="Game Boost" Style="{StaticResource HeaderText}" Margin="0,0,0,8"/>
            <TextBlock Text="Toggle a profile on or off"
                       Style="{StaticResource SubHeaderText}" Margin="0,0,0,24"/>

            <UniformGrid Columns="3" Margin="0,0,0,18">
                <!-- Basic -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                    <StackPanel>
                        <Image Source="{StaticResource IconModeBasic}" Width="64" Height="64"
                               HorizontalAlignment="Left" Margin="0,0,0,8"/>
                        <TextBlock Text="BASIC MODE" Style="{StaticResource SectionLabel}" Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="Lightweight gaming preset"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="18" FontWeight="SemiBold" Margin="0,4,0,8"/>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{StaticResource Text2Brush}"
                                   FontSize="12" Margin="0,0,0,18">
                            Game Mode + mouse acceleration off + High-Performance power plan. Safe for most systems.
                        </TextBlock>
                        <Border Background="{StaticResource StrokeBrush}" Height="1" Margin="0,0,0,14"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Enable" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="1" x:Name="BasicToggle"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          IsChecked="{Binding IsBasicActive, Mode=TwoWay}"
                                          Click="BasicToggleClick"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Performance -->
                <Border Style="{StaticResource CardBorder}" Margin="4,0">
                    <StackPanel>
                        <Image Source="{StaticResource IconModePerformance}" Width="64" Height="64"
                               HorizontalAlignment="Left" Margin="0,0,0,8"/>
                        <TextBlock Text="PERFORMANCE MODE" Style="{StaticResource SectionLabel}" Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="Maximum tuning preset"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="18" FontWeight="SemiBold" Margin="0,4,0,8"/>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{StaticResource Text2Brush}"
                                   FontSize="12" Margin="0,0,0,18">
                            Everything in Basic + timer resolution + hardware GPU scheduling + multimedia priority maxed + telemetry trimmed.
                        </TextBlock>
                        <Border Background="{StaticResource StrokeBrush}" Height="1" Margin="0,0,0,14"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Enable" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="1" x:Name="PerformanceToggle"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          IsChecked="{Binding IsPerformanceActive, Mode=TwoWay}"
                                          Click="PerformanceToggleClick"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Aggressive -->
                <Border Style="{StaticResource CardBorder}" Margin="8,0,0,0">
                    <StackPanel>
                        <Image Source="{StaticResource IconModeAggressive}" Width="64" Height="64"
                               HorizontalAlignment="Left" Margin="0,0,0,8"/>
                        <TextBlock Text="AGGRESSIVE MODE" Style="{StaticResource SectionLabel}" Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="All-out tuning preset"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="18" FontWeight="SemiBold" Margin="0,4,0,8"/>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{StaticResource Text2Brush}"
                                   FontSize="12" Margin="0,0,0,18">
                            Everything in Performance + Cortana off + modern standby off + hibernation off. May break some apps.
                        </TextBlock>
                        <Border Background="{StaticResource StrokeBrush}" Height="1" Margin="0,0,0,14"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Enable" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="1" x:Name="AggressiveToggle"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          IsChecked="{Binding IsAggressiveActive, Mode=TwoWay}"
                                          Click="AggressiveToggleClick"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <TextBlock Text="STATUS" Style="{StaticResource SectionLabel}"/>
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,18">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource Text0Brush}"
                           FontSize="13" TextWrapping="Wrap"/>
            </Border>

            <TextBlock Foreground="{StaticResource Text3Brush}"
                       FontSize="12" TextWrapping="Wrap">
                Tip: To attach a profile to a specific game so it auto-applies on launch, go to the Library tab and pick a profile from the dropdown on each game tile.
            </TextBlock>
        </StackPanel>
    </ScrollViewer>
</UserControl>
