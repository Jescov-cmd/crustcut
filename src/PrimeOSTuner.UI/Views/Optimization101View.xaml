<UserControl x:Class="PrimeOSTuner.UI.Views.Optimization101View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:PrimeOSTuner.UI.Controls">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="Optimization 101" Style="{StaticResource HeaderText}" Margin="0,0,0,8"/>
            <TextBlock Text="Real optimizations the app won't do for you — BIOS settings, driver panels, hardware. Step-by-step guides you follow yourself."
                       Style="{StaticResource SubHeaderText}"/>
            <TextBlock Text="{Binding ProgressText}" Foreground="{StaticResource Text3Brush}"
                       FontSize="12" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Body: categories | guide list | detail -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Category filter -->
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Categories}"
                     SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="0,0,0,2"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="chip" CornerRadius="6" Padding="10,8"
                                            Background="Transparent">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="chip" Property="Background" Value="#15FFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="chip" Property="Background" Value="#22FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource Text2Brush}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Guide cards -->
            <ListBox Grid.Column="1" Margin="14,0"
                     ItemsSource="{Binding VisibleGuides}"
                     SelectedItem="{Binding SelectedGuide, Mode=TwoWay}"
                     Background="Transparent" BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="0,0,0,8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="card" CornerRadius="8" Padding="14,12"
                                            Background="{StaticResource Bg1Brush}"
                                            BorderBrush="{StaticResource StrokeBrush}"
                                            BorderThickness="1">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="card" Property="BorderBrush" Value="#55FFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="card" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                            <Setter TargetName="card" Property="Background" Value="#12FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Title}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource Text0Brush}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Column="1" Text="✓" FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource GoodBrush}" Margin="8,0,0,0"
                                           Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVisibility}}"/>
                            </Grid>
                            <TextBlock Margin="0,6,0,0" FontSize="11" Foreground="{StaticResource Text3Brush}">
                                <Run Text="{Binding Category, Mode=OneWay}"/><Run Text="   ·   "/><Run Text="{Binding Difficulty, Mode=OneWay}"/><Run Text="   ·   "/><Run Text="{Binding RiskLabel, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Text="{Binding EstimatedTime}" FontSize="11"
                                       Foreground="{StaticResource Text3Brush}"
                                       Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Detail -->
            <Border Grid.Column="2"
                    Background="{StaticResource Bg1Brush}"
                    BorderBrush="{StaticResource StrokeBrush}"
                    BorderThickness="1" CornerRadius="8">
                <Grid>
                    <TextBlock Text="Pick a guide on the left to see the full walkthrough."
                               Foreground="{StaticResource Text3Brush}" FontSize="13"
                               HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedGuide}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="22,20">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedGuide}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedGuide.Title}"
                                       FontFamily="Segoe UI Variable Display, Segoe UI"
                                       FontSize="20" FontWeight="SemiBold"
                                       Foreground="{StaticResource Text0Brush}" TextWrapping="Wrap"/>
                            <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="{StaticResource Text2Brush}">
                                <Run Text="{Binding SelectedGuide.Difficulty, Mode=OneWay}"/><Run Text="     ·     "/><Run Text="{Binding SelectedGuide.RiskLabel, Mode=OneWay}"/><Run Text="     ·     "/><Run Text="{Binding SelectedGuide.EstimatedTime, Mode=OneWay}"/>
                            </TextBlock>

                            <Border Margin="0,14,0,0" Padding="12,9" CornerRadius="6"
                                    Background="#2BE5484D" BorderBrush="#80E5484D" BorderThickness="1"
                                    Visibility="{Binding SelectedGuide.IsHighRisk, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock FontSize="12" FontWeight="SemiBold"
                                           Foreground="#FFB3B5" TextWrapping="Wrap"
                                           Text="High risk — a mistake here can stop your PC from booting or damage hardware. Read every step and all the warnings before you start."/>
                            </Border>

                            <Border Margin="0,14,0,0" Padding="12,9" CornerRadius="6"
                                    Background="#1F4DA3FF"
                                    Visibility="{Binding SelectedGuide.HasStateBadge, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="{Binding SelectedGuide.StateBadge}" FontSize="12"
                                           Foreground="{StaticResource Text0Brush}" TextWrapping="Wrap"/>
                            </Border>

                            <ctl:MarkdownView Markdown="{Binding SelectedGuide.Body}" Margin="0,2,0,0"/>

                            <Button Content="{Binding SelectedGuide.DoneLabel}"
                                    Command="{Binding ToggleCompletedCommand}"
                                    HorizontalAlignment="Left" Margin="0,20,0,0" Padding="16,9"
                                    Cursor="Hand"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
