<UserControl x:Class="PrimeOSTuner.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:PrimeOSTuner.UI.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,16,0">
        <StackPanel Margin="0,0,0,32">
            <TextBlock Text="Dashboard" Style="{StaticResource HeaderText}" Margin="0,0,0,8"/>
            <TextBlock Text="Your PC at a glance"
                       Style="{StaticResource SubHeaderText}" Margin="0,0,0,20"/>

            <!-- Active profile banner (only when applied) -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16"
                    BorderBrush="{StaticResource AccentGradientBrush}"
                    BorderThickness="2"
                    Visibility="{Binding HasActiveProfile, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="ACTIVE PROFILE" Style="{StaticResource SectionLabel}"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Foreground="{StaticResource Text0Brush}" FontSize="14" FontWeight="SemiBold">
                        <Run Text="{Binding ActiveProfileName}"/>
                        <Run Text=" applied for "/>
                        <Run Text="{Binding ActiveGameName}"/>
                    </TextBlock>
                    <TextBlock Text="Tweaks revert automatically when the game closes."
                               Foreground="{StaticResource Text2Brush}" FontSize="11" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Tile grid -->
            <WrapPanel HorizontalAlignment="Center">

                <!-- Boost Score tile -->
                <Border Style="{StaticResource CardBorder}" Width="280" Height="180" Margin="0,0,12,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="BOOST SCORE" Style="{StaticResource SectionLabel}"/>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <c:BoostScoreRing Grid.Column="0" Score="{Binding BoostScore}" Margin="0,0,16,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding BoostScoreTier}"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="{Binding BoostScoreSubtitle}"
                                           Foreground="{StaticResource Text2Brush}"
                                           FontSize="11" Margin="0,4,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Optimize Now tile -->
                <Border Style="{StaticResource CardBorder}" Width="280" Height="180" Margin="0,0,12,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="ONE-CLICK OPTIMIZE" Style="{StaticResource SectionLabel}"/>
                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="Apply safe tweaks"
                                       FontFamily="Segoe UI Variable Display, Segoe UI"
                                       FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="Auto-creates restore point"
                                       Foreground="{StaticResource Text2Brush}"
                                       FontSize="11" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Button Grid.Row="2"
                                x:Name="OptimizeButton"
                                Style="{StaticResource PrimaryActionButton}"
                                Content="Optimize Now"
                                Click="OptimizeButton_Click"
                                HorizontalAlignment="Stretch"/>
                    </Grid>
                </Border>

                <!-- CPU tile -->
                <Border Style="{StaticResource CardBorder}" Width="280" Height="180" Margin="0,0,12,12" Padding="20,16">
                    <c:StatCard StatName="CPU"
                                ValueText="{Binding CpuPercent, StringFormat='{}{0:F0}%'}"
                                SubText=""
                                History="{Binding CpuHistory}"/>
                </Border>

                <!-- Memory tile -->
                <Border Style="{StaticResource CardBorder}" Width="280" Height="180" Margin="0,0,12,12" Padding="20,16">
                    <c:StatCard StatName="MEMORY"
                                ValueText="{Binding RamPercent, StringFormat='{}{0:F0}%'}"
                                SubText=""
                                History="{Binding RamHistory}"/>
                </Border>

                <!-- GPU tile -->
                <Border Style="{StaticResource CardBorder}" Width="280" Height="180" Margin="0,0,12,12" Padding="20,16">
                    <c:StatCard StatName="GPU"
                                ValueText="{Binding GpuPercent, StringFormat='{}{0:F0}%'}"
                                SubText=""
                                History="{Binding GpuHistory}"/>
                </Border>

                <!-- Network tile -->
                <Border Style="{StaticResource CardBorder}" Width="280" Height="180" Margin="0,0,12,12" Padding="20,16">
                    <c:StatCard StatName="NETWORK"
                                ValueText="{Binding NetworkText}"
                                SubText=""
                                History="{Binding NetHistory}"/>
                </Border>

            </WrapPanel>

            <TextBlock x:Name="OptimizeStatus"
                       Foreground="{StaticResource Text3Brush}"
                       FontSize="11" Margin="0,12,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
