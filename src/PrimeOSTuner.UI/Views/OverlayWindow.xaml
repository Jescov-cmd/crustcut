<Window x:Class="PrimeOSTuner.UI.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Focusable="False"
        Title="Crustcut Overlay">
    <Window.Resources>
        <!-- Minimalistic OSD text: bright, semibold, monospaced, with a soft shadow so it
             stays legible over any game scene (no panel background needed). -->
        <Style x:Key="OsdText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFF6F6F6"/>
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="{Binding FontSize}"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="5" ShadowDepth="1" Opacity="0.95"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="Root" Padding="10,7" CornerRadius="8">
        <Border.Style>
            <Style TargetType="Border">
                <!-- See-through normally; a subtle card + accent outline only in edit mode. -->
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding EditMode}" Value="True">
                        <Setter Property="Background" Value="#73000000"/>
                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                        <Setter Property="BorderThickness" Value="1.5"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <StackPanel>
            <TextBlock Text="◇ drag to move — press the hotkey again to lock"
                       FontSize="11" Foreground="{StaticResource AccentBrush}"
                       Margin="0,0,0,4"
                       Visibility="{Binding EditMode, Converter={StaticResource BoolToVisibility}}"/>

            <TextBlock Text="{Binding FpsText}"  Style="{StaticResource OsdText}"
                       Foreground="{StaticResource AccentBrush}"
                       Visibility="{Binding ShowFps, Converter={StaticResource BoolToVisibility}}"/>
            <TextBlock Text="{Binding CpuText}"  Style="{StaticResource OsdText}"
                       Visibility="{Binding ShowCpu, Converter={StaticResource BoolToVisibility}}"/>
            <TextBlock Text="{Binding GpuText}"  Style="{StaticResource OsdText}"
                       Visibility="{Binding ShowGpu, Converter={StaticResource BoolToVisibility}}"/>
            <TextBlock Text="{Binding RamText}"  Style="{StaticResource OsdText}"
                       Visibility="{Binding ShowRam, Converter={StaticResource BoolToVisibility}}"/>
            <TextBlock Text="{Binding VramText}" Style="{StaticResource OsdText}"
                       Visibility="{Binding ShowVram, Converter={StaticResource BoolToVisibility}}"/>
            <TextBlock Text="{Binding NetText}"  Style="{StaticResource OsdText}"
                       Visibility="{Binding ShowNet, Converter={StaticResource BoolToVisibility}}"/>
        </StackPanel>
    </Border>
</Window>
