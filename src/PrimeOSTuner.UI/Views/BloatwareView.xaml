<UserControl x:Class="PrimeOSTuner.UI.Views.BloatwareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,16,0">
        <StackPanel Margin="0,0,0,32">

            <TextBlock Text="Bloatware" Style="{StaticResource HeaderText}" Margin="0,0,0,8"/>
            <TextBlock Text="Detected pre-installed apps you can disable or uninstall."
                       Style="{StaticResource SubHeaderText}" Margin="0,0,0,24"/>

            <!-- Summary banner -->
            <Border Style="{StaticResource CardBorder}" Padding="20,16" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DetectedCount, StringFormat={}{0} item(s) detected}"
                                   FontWeight="SemiBold" FontSize="20"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   Foreground="{StaticResource Text0Brush}"/>
                        <TextBlock Text="{Binding Status}"
                                   Foreground="{StaticResource Text2Brush}"
                                   FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Click="RefreshClick"
                            IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource IconRestart}" Width="14" Height="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Refresh scan" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Single list card with rows separated by subtle dividers -->
            <Border Style="{StaticResource CardBorder}" Padding="0">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="20,14"
                                    BorderBrush="#22FFFFFF"
                                    BorderThickness="0,0,0,1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#0DFFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Tier icon -->
                                    <Image Grid.Column="0"
                                           Width="24" Height="24"
                                           Margin="0,0,16,0" VerticalAlignment="Center"
                                           ToolTip="{Binding TierLabel}">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Source" Value="{StaticResource IconCheck}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TierLabel}" Value="Risky">
                                                        <Setter Property="Source" Value="{StaticResource IconWarning}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TierLabel}" Value="Blocked">
                                                        <Setter Property="Source" Value="{StaticResource IconLock}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>

                                    <!-- Name + identifier -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="SemiBold" FontSize="14"
                                                   Foreground="{StaticResource Text0Brush}"/>
                                        <TextBlock Text="{Binding AppxName}"
                                                   Foreground="{StaticResource Text3Brush}"
                                                   FontSize="11" Margin="0,2,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <!-- Status pill -->
                                    <Border Grid.Column="2"
                                            CornerRadius="4" Padding="8,3"
                                            Margin="12,0"
                                            VerticalAlignment="Center"
                                            Background="#1A1A1A"
                                            BorderBrush="#3D3D3D" BorderThickness="1">
                                        <TextBlock Text="{Binding StatusText}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Text2Brush}"/>
                                    </Border>

                                    <!-- Actions -->
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="Disable" Click="DisableClick" Tag="{Binding}"
                                                MinWidth="80" Padding="14,6"
                                                FontSize="12"
                                                Margin="0,0,8,0"/>
                                        <Button Content="Uninstall" Click="UninstallClick" Tag="{Binding}"
                                                IsEnabled="{Binding CanUninstall}"
                                                ToolTip="{Binding RiskNote}"
                                                MinWidth="80" Padding="14,6"
                                                FontSize="12"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
