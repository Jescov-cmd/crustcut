<Window x:Class="PrimeOSTuner.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Crustcut"
        Height="780" Width="1240"
        MinWidth="640" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <!-- Top tab: transparent button with accent-gradient underline when active -->
        <Style x:Key="TopTab" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource Text2Brush}"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,1,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="bg" Background="{TemplateBinding Background}"
                                    CornerRadius="6,6,0,0" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border x:Name="underline" Height="2" CornerRadius="1"
                                    VerticalAlignment="Bottom" Margin="10,0"
                                    Background="Transparent"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#15FFFFFF"/>
                                <Setter Property="Foreground" Value="{StaticResource Text0Brush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopTabActive" TargetType="Button" BasedOn="{StaticResource TopTab}">
            <Setter Property="Foreground" Value="{StaticResource Text0Brush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="bg" Background="#10FFFFFF"
                                    CornerRadius="6,6,0,0" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Height="2" CornerRadius="1"
                                    VerticalAlignment="Bottom" Margin="10,0"
                                    Background="{StaticResource AccentGradientBrush}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
    <DockPanel LastChildFill="True">
        <!-- Top bar: brand · tabs · watcher. TopBarBrush is alpha-blended; combined with
             the Mica backdrop set in code-behind, this gives a translucent title-bar feel. -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource TopBarBrush}"
                BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,0,0,0">
            <Grid Height="48">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Brand: bread PNG (warm brown tones baked in) + Crustcut wordmark. -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,28,0">
                    <Image Source="pack://application:,,,/Assets/Brand/bread.png"
                           Width="24" Height="24"
                           VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock Text="Crustcut"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="15" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="VersionText" Text="v0.6.1"
                                   FontFamily="Segoe UI Variable Text, Segoe UI"
                                   FontSize="10"
                                   Foreground="{StaticResource Text3Brush}"
                                   Margin="8,2,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Tabs (icon + label) — horizontally scrollable, mouse-wheel scrolls left/right -->
                <ScrollViewer Grid.Column="1"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled"
                              VerticalAlignment="Bottom"
                              Margin="0,0,12,0"
                              shell:WindowChrome.IsHitTestVisibleInChrome="True"
                              PreviewMouseWheel="TabsScroll_PreviewMouseWheel">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="NavDashboard" Tag="Dashboard" Click="NavButton_Click" Style="{StaticResource TopTabActive}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource IconDashboard}" Width="16" Height="16" Margin="0,0,6,0"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavOptimize" Tag="Optimize" Click="NavButton_Click" Style="{StaticResource TopTab}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource IconOptimize}" Width="16" Height="16" Margin="0,0,6,0"/>
                            <TextBlock Text="Optimize" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavGameBoost" Tag="GameBoost" Click="NavButton_Click" Style="{StaticResource TopTab}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource IconGameBoost}" Width="16" Height="16" Margin="0,0,6,0"/>
                            <TextBlock Text="Game Boost" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavGameLibrary" Tag="GameLibrary" Click="NavButton_Click" Style="{StaticResource TopTab}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource IconGameLibrary}" Width="16" Height="16" Margin="0,0,6,0"/>
                            <TextBlock Text="Library" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavBloatware" Tag="Bloatware" Click="NavButton_Click" Style="{StaticResource TopTab}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource IconBloatware}" Width="16" Height="16" Margin="0,0,6,0"/>
                            <TextBlock Text="Bloatware" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavMemoryPriority" Tag="MemoryPriority" Click="NavButton_Click" Style="{StaticResource TopTab}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource IconMemoryPriority}" Width="16" Height="16" Margin="0,0,6,0"/>
                            <TextBlock Text="Memory Priority" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavOptimization101" Tag="Optimization101" Click="NavButton_Click" Style="{StaticResource TopTab}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource IconEducation}" Width="16" Height="16" Margin="0,0,6,0"/>
                            <TextBlock Text="Guides" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavHistory" Tag="History" Click="NavButton_Click" Style="{StaticResource TopTab}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource IconHistory}" Width="16" Height="16" Margin="0,0,6,0"/>
                            <TextBlock Text="History" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavSentinel" Tag="Sentinel" Click="NavButton_Click" Style="{StaticResource TopTab}">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{StaticResource IconSentinel}" Width="16" Height="16" Margin="0,0,6,0"/>
                                <TextBlock Text="Sentinel" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Ellipse x:Name="SentinelDot" Width="6" Height="6" Fill="#FF6A6A"
                                     HorizontalAlignment="Right" VerticalAlignment="Top"
                                     Margin="0,4,-2,0"
                                     Visibility="{Binding HasActiveProblem, Converter={StaticResource BoolToVisibility}}">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#FF6A6A" ShadowDepth="0" BlurRadius="6" Opacity="0.85"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Grid>
                    </Button>
                    <Button x:Name="NavSettings" Tag="Settings" Click="NavButton_Click" Style="{StaticResource TopTab}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource IconSettings}" Width="16" Height="16" Margin="0,0,6,0"/>
                            <TextBlock Text="Settings" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                </ScrollViewer>

                <!-- Watcher status + toggle -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Margin="0,0,16,0">
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource Text4Brush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsWatching}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource GoodBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock x:Name="WatcherStatusText"
                               Text="{Binding StatusText}"
                               FontSize="12" Foreground="{StaticResource Text2Brush}"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ToggleButton x:Name="WatcherToggle"
                                  Style="{StaticResource ToggleSwitchStyle}"
                                  IsChecked="{Binding IsWatching, Mode=TwoWay}"
                                  VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Window buttons: minimize · maximize/restore · close -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Stretch"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinBtn" Click="MinimizeClick"
                            Width="46" Height="48"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource Text1Brush}" Cursor="Hand"
                            ToolTip="Minimize">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="{TemplateBinding Background}">
                                    <Path Data="M 0,5 L 10,5" Stroke="{TemplateBinding Foreground}" StrokeThickness="1.4"
                                          HorizontalAlignment="Center" VerticalAlignment="Center" Width="10" Height="10"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#15FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="MaxBtn" Click="MaxRestoreClick"
                            Width="46" Height="48"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource Text1Brush}" Cursor="Hand"
                            ToolTip="Maximize">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="{TemplateBinding Background}">
                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="10" Height="10">
                                        <Path x:Name="MaxIcon" Data="M 0,0 L 10,0 L 10,10 L 0,10 Z"
                                              Stroke="{TemplateBinding Foreground}" StrokeThickness="1.2" Fill="Transparent"/>
                                        <Path x:Name="RestoreIcon" Visibility="Collapsed"
                                              Data="M 2,2 L 10,2 L 10,10 M 0,4 L 8,4 L 8,12 L 0,12 Z"
                                              Stroke="{TemplateBinding Foreground}" StrokeThickness="1.2" Fill="Transparent"/>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#15FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="CloseBtn" Click="CloseClick"
                            Width="46" Height="48"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource Text1Brush}" Cursor="Hand"
                            ToolTip="Close">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="{TemplateBinding Background}">
                                    <Path Data="M 0,0 L 10,10 M 10,0 L 0,10"
                                          Stroke="{TemplateBinding Foreground}" StrokeThickness="1.4"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          HorizontalAlignment="Center" VerticalAlignment="Center" Width="10" Height="10"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Page host — wrapped in a solid-bg Border so Mica only shows in the title bar,
             not behind the main content. -->
        <Border Background="{StaticResource Bg0Brush}">
            <ContentControl x:Name="PageHost" Margin="32,24,32,32"/>
        </Border>
    </DockPanel>
    </Grid>
</Window>
